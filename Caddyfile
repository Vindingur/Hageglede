# Caddyfile for hageglede.no
# Alternative reverse proxy configuration if Traefik is not used

# Main domain with CNAME to projects.vindingur.no
hageglede.no {
    # Reverse proxy to FastAPI application
    reverse_proxy http://app:8000 {
        # Health check endpoint
        health_uri /health
        health_interval 30s
        health_timeout 5s
    }
    
    # Enable automatic HTTPS with Let's Encrypt
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    
    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
    
    # Compression
    encode gzip zstd
    
    # Logging
    log {
        output stdout
        format json
        level INFO
    }
}

# Path-based routing for projects.vindingur.no/hageglede
projects.vindingur.no {
    handle_path /hageglede/* {
        # Strip the prefix before forwarding
        rewrite * /{path}
        
        # Proxy to the same app container
        reverse_proxy http://app:8000 {
            health_uri /health
            health_interval 30s
            health_timeout 5s
        }
        
        # Same security headers
        header {
            X-Content-Type-Options nosniff
            X-Frame-Options DENY
            X-XSS-Protection "1; mode=block"
            Referrer-Policy strict-origin-when-cross-origin
            -Server
        }
    }
    
    # Static file serving for the main projects site
    handle {
        root * /var/www/projects
        file_server
    }
    
    # TLS configuration
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
}

# Global options
{
    # Email for Let's Encrypt notifications
    email dev@vindingur.no
    
    # Automatic HTTPS with staging for testing
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
    
    # Default logging
    log {
        output stdout
        level INFO
    }
    
    # Admin API (optional)
    admin :2019
    
    # Persist certificates
    storage file_system {
        root /data/caddy
    }
}

# Server configuration block
:443 {
    # Import the domain configurations
    import Caddyfile
}

# HTTP to HTTPS redirect
:80 {
    redir https://{host}{uri} permanent
}

# Docker health check endpoint
:8080 {
    respond /health 200 {
        body "OK"
    }
}